---
import Layout from '../layouts/Layout.astro';
// selected-work.astro
const works = [
  {
    company: "Felkrem",
    project: "Branding",
    type: "Redeisgn",
    image: "https://via.placeholder.com/600x400" // Placeholder image
  },
  {
    company: "Neerme",
    project: "Project Name 2",
    type: "Project Type 2",
    image: "https://via.placeholder.com/600x400"
  }
];
---

<Layout>
	<main class="min-h-screen flex flex-col items-center justify-center px-4 fade-section" id="hero-main">
		<h1 class="text-7xl font-bold mb-4">CHRISTIAN PUGA</h1>
		<p class="text-xl text-gray-300">Hi!, I make digital stuff look and feel awesome.</p>
		
		<div class="absolute bottom-8 flex flex-col items-center">
		  <span class="text-gray-400">Scroll to explore</span>
		  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mt-2 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
		  </svg>
		</div>
	</main>

	<section class="max-w-[880px] mx-auto text-white py-10 px-6 fade-section" id="work-section">
		<h2 class="text-2xl font-semibold mb-6 text-left">Selected work</h2>
	  
		<div class="space-y-8">
		  {works.map((work) => (
			<div class="rounded-xl overflow-hidden">
			  <div class="w-full h-[540px] bg-white"></div>
			  <div class="flex justify-between items-center py-4">
				<div>
				  <h3 class="text-lg font-medium">{work.company}</h3>
				  <p class="text-sm text-gray-400">{work.project}</p>
				</div>
				<span class="text-sm text-gray-400">{work.type}</span>
			  </div>
			</div>
		  ))}
		</div>
	</section>
</Layout>

<style>
	.fade-section {
		opacity: 0;
		transform: translateY(20px);
		transition: all 1s ease-out;
	}

	.fade-in {
		opacity: 1;
		transform: translateY(20px);
	}

	/* Special case for hero section to start visible */
	#hero-main {
		opacity: 1;
		transform: translateY(0);
	}

	#hero-main.fade-out {
		opacity: 0;
		transform: translateY(-20px);
	}
</style>

<script>
	const observerOptions = {
		root: null,
		threshold: 0.2,
		rootMargin: "0px"
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.target.id === 'hero-main') {
				// Hero section fades out when scrolling down
				if (!entry.isIntersecting) {
					entry.target.classList.add('fade-out');
				} else {
					entry.target.classList.remove('fade-out');
				}
			} else {
				// Work section fades in when scrolling down
				if (entry.isIntersecting) {
					entry.target.classList.add('fade-in');
				} else {
					entry.target.classList.remove('fade-in');
				}
			}
		});
	}, observerOptions);

	// Start observing both sections
	document.addEventListener('DOMContentLoaded', () => {
		const mainSection = document.getElementById('hero-main');
		const workSection = document.getElementById('work-section');
		
		if (mainSection) observer.observe(mainSection);
		if (workSection) observer.observe(workSection);
	});
</script>
