</Layout>

<style>
	.fade-section {
		opacity: 1;
		transform: translateY(0);
		transition: all 1s ease-out;
	}

	#hero-main.fade-out {
		opacity: 0;
		transform: translateY(-20px);
	}

	.content-animation-container {
		position: relative;
	}

	.content-set {
		opacity: 1;
		transition: opacity 0.5s ease-in-out;
	}

	.content-set.hidden {
		opacity: 0;
		position: absolute;
	}

	.language-btn {
		position: relative;
		padding: 0.5rem 1rem;
		background: transparent;
		border: none;
		font-size: 1rem;
		cursor: pointer;
	}

	.language-btn.active {
		color: white;
	}

	.language-btn::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 100%;
		height: 1px;
		background-color: white;
		transform: scaleX(0);
		transition: transform 0.3s ease;
	}

	.language-btn.active::after,
	.language-btn:hover::after {
		transform: scaleX(1);
	}

	#hero-title,
	#hero-subtitle {
		opacity: 1;
		transition: opacity 0.3s ease-in-out;
	}
</style>

<script is:inline>
	// Store content object in window to access it in functions
	window.content = {
		en: {
			title: "Hey, I'm Chris. I design cool stuff that just makes sense.",
			subtitle: "Simple, intuitive, and user-focused. Take a look around!"
		},
		es: {
			title: "Hola, soy Chris. Diseño cosas geniales que tienen sentido.",
			subtitle: "Simple, intuitivo y centrado en el usuario. ¡Echa un vistazo!"
		},
	};

	class TextScramble {
		constructor(el) {
			this.el = el;
			this.chars = '!<>-_\\/[]{}—=+*^?#________';
			this.update = this.update.bind(this);
		}
		
		setText(newText) {
			const oldText = this.el.innerText;
			const length = Math.max(oldText.length, newText.length);
			const promise = new Promise((resolve) => this.resolve = resolve);
			this.queue = [];
			for (let i = 0; i < length; i++) {
				const from = oldText[i] || '';
				const to = newText[i] || '';
				const start = Math.floor(Math.random() * 40);
				const end = start + Math.floor(Math.random() * 40);
				this.queue.push({ from, to, start, end });
			}
			cancelAnimationFrame(this.frameRequest);
			this.frame = 0;
			this.update();
			return promise;
		}
		
		update() {
			let output = '';
			let complete = 0;
			for (let i = 0, n = this.queue.length; i < n; i++) {
				let { from, to, start, end, char } = this.queue[i];
				if (this.frame >= end) {
					complete++;
					output += to;
				} else if (this.frame >= start) {
					if (!char || Math.random() < 0.28) {
						char = this.randomChar();
						this.queue[i].char = char;
					}
					output += `<span class="text-emerald-400">${char}</span>`;
				} else {
					output += from;
				}
			}
			this.el.innerHTML = output;
			if (complete === this.queue.length) {
				this.resolve();
			} else {
				this.frameRequest = requestAnimationFrame(this.update);
				this.frame++;
			}
		}
		
		randomChar() {
			return this.chars[Math.floor(Math.random() * this.chars.length)];
		}
	}

	function initializeScramble() {
		const titleScrambler = new TextScramble(document.getElementById('hero-title'));
		const subtitleScrambler = new TextScramble(document.getElementById('hero-subtitle'));
		const languages = ['en', 'es']; // Only English and Spanish
		let currentLang = 'en';
		let isLanguageSelected = false;
		let intervalId;

		// Function to update button states
		function updateButtons(lang) {
			document.querySelectorAll('.language-btn').forEach(btn => {
				const isActive = btn.dataset.lang === lang;
				btn.classList.toggle('active', isActive);
				btn.classList.toggle('text-white', isActive);
				btn.classList.toggle('text-gray-400', !isActive);
			});
		}

		// Function to scramble text
		function scrambleText(lang) {
			if (!window.content[lang]) {
				console.error('Language not found:', lang);
				return;
			}
			currentLang = lang;
			updateButtons(lang);
			titleScrambler.setText(window.content[lang].title);
			subtitleScrambler.setText(window.content[lang].subtitle);
		}

		// Start alternating animation between English and Spanish
		function startAlternatingAnimation() {
			// Clear any existing interval
			if (intervalId) {
				clearInterval(intervalId);
			}

			// Reset language selection state
			isLanguageSelected = false;

			// Set interval to switch between English and Spanish
			intervalId = setInterval(() => {
				if (!isLanguageSelected) {
					// Simply toggle between en and es
					const nextLang = currentLang === 'en' ? 'es' : 'en';
					scrambleText(nextLang);
				}
			}, 5000); // Changed to 5 seconds (5000ms)
		}

		// Add click handlers to buttons
		document.querySelectorAll('.language-btn').forEach(btn => {
			btn.addEventListener('click', (e) => {
				const lang = e.currentTarget.dataset.lang;
				if (lang) {
					isLanguageSelected = true;
					clearInterval(intervalId);
					scrambleText(lang);
				}
			});
		});

		// Start the alternating animation
		startAlternatingAnimation();
	}


	
	// Initialize on both DOMContentLoaded and astro:page-load
	document.addEventListener('DOMContentLoaded', initializeScramble);
	document.addEventListener('astro:page-load', initializeScramble);
</script>
