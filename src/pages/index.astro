<style>
	.fade-section {
		opacity: 1;
		transform: translateY(0);
		transition: all 1s ease-out;
	}

	#hero-main.fade-out {
		opacity: 0;
		transform: translateY(-20px);
	}
</style>

<script>
	let cleanup: (() => void) | null = null;

	function initializeObservers() {
		const fadeSectionObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (!entry.isIntersecting) {
					entry.target.classList.add('fade-out');
				} else {
					entry.target.classList.remove('fade-out');
				}
			});
		}, {
			threshold: 0.3,
			rootMargin: '-10% 0px'
		});

		// Only observe hero section
		const heroSection = document.getElementById('hero-main');
		if (heroSection) {
			fadeSectionObserver.observe(heroSection);
		}

		return () => {
			fadeSectionObserver.disconnect();
		};
	}

	// Initialize on first load
	document.addEventListener('DOMContentLoaded', () => {
		cleanup = initializeObservers();
	});

	// Initialize on view transitions
	document.addEventListener('astro:page-load', () => {
		if (cleanup) cleanup();
		cleanup = initializeObservers();
	});

	// Cleanup on page unload
	document.addEventListener('astro:before-swap', () => {
		if (cleanup) cleanup();
	});
</script>
