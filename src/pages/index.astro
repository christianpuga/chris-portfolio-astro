<style>
	.fade-section {
		opacity: 1;
		transform: translateY(0);
		transition: all 1s ease-out;
	}

	#hero-main.fade-out {
		opacity: 0;
		transform: translateY(-20px);
	}

	.content-animation-container {
		position: relative;
	}

	.content-set {
		opacity: 1;
		transition: opacity 0.5s ease-in-out;
	}

	.content-set.hidden {
		opacity: 0;
		position: absolute;
	}

	.language-btn.active {
		color: white;
		position: relative;
	}

	.language-btn.active::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 100%;
		height: 1px;
		background-color: white;
	}
</style>

<script>
	let cleanup: (() => void) | null = null;

	function initializeObservers() {
		const fadeSectionObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (!entry.isIntersecting) {
					entry.target.classList.add('fade-out');
				} else {
					entry.target.classList.remove('fade-out');
				}
			});
		}, {
			threshold: 0.3,
			rootMargin: '-10% 0px'
		});

		// Only observe hero section
		const heroSection = document.getElementById('hero-main');
		if (heroSection) {
			fadeSectionObserver.observe(heroSection);
		}

		return () => {
			fadeSectionObserver.disconnect();
		};
	}

	class TextScramble {
		private el: Element;
		private chars: string;
		private queue: number;
		private frameRequest: number;
		private frame: number;
		private resolve: Function | null;
		private queue_length: number;

		constructor(el: Element) {
			this.el = el;
			this.chars = '!<>-_\\/[]{}—=+*^?#________';
			this.queue = 0;
			this.frame = 0;
			this.frameRequest = 0;
			this.resolve = null;
			this.queue_length = 0;
		}

		setText(newText: string) {
			const oldText = this.el.textContent || '';
			const length = Math.max(oldText.length, newText.length);
			this.queue_length = length;

			const promise = new Promise((resolve) => this.resolve = resolve);

			this.queue = 0;
			const frames = [];

			for (let i = 0; i < length; i++) {
				const from = oldText[i] || '';
				const to = newText[i] || '';
				const start = Math.floor(Math.random() * 40);
				const end = start + Math.floor(Math.random() * 40);
				frames.push({ from, to, start, end });
			}

			cancelAnimationFrame(this.frameRequest);
			this.frame = 0;

			const update = () => {
				let output = '';
				let complete = 0;

				for (let i = 0; i < length; i++) {
					const { from, to, start, end } = frames[i];
					if (this.frame >= end) {
						complete++;
						output += to;
					} else if (this.frame >= start) {
						output += this.chars[Math.floor(Math.random() * this.chars.length)];
					} else {
						output += from;
					}
				}

				this.el.textContent = output;

				if (complete === length) {
					if (this.resolve) this.resolve();
				} else {
					this.frameRequest = requestAnimationFrame(update);
					this.frame++;
				}
			};

			update();
			return promise;
		}
	}

	function initializeLanguageSelector() {
		const contentSets = document.querySelectorAll('.content-set');
		const languageButtons = document.querySelectorAll('.language-btn');
		let currentLangIndex = 0;
		let isAutoChanging = true;
		let intervalId: number;

		// Initialize scramblers for all h1 and p elements
		const h1Scrambler = new TextScramble(document.querySelector('h1')!);
		const pScrambler = new TextScramble(document.querySelector('p')!);

		const texts = {
			en: {
				h1: "Hey, I'm Christian. I design cool stuff that just makes sense.",
				p: "Simple, intuitive, and user-focused. Take a look around!"
			},
			es: {
				h1: "Hola, soy Christian. Diseño cosas geniales que tienen sentido.",
				p: "Simple, intuitivo y centrado en el usuario. ¡Echa un vistazo!"
			},
			fr: {
				h1: "Salut, je suis Christian. Je conçois des choses cool qui ont du sens.",
				p: "Simple, intuitif et centré sur l'utilisateur. Jetez un coup d'œil!"
			},
			de: {
				h1: "Hi, ich bin Christian. Ich gestalte coole Dinge, die Sinn machen.",
				p: "Einfach, intuitiv und benutzerzentriert. Schau dich um!"
			}
		};

		const languages = ['en', 'es', 'fr', 'de'];

		async function changeLanguage(langIndex: number) {
			const lang = languages[langIndex];
			await Promise.all([
				h1Scrambler.setText(texts[lang].h1),
				pScrambler.setText(texts[lang].p)
			]);
		}

		function autoChangeLanguage() {
			// Trigger first change immediately
			changeLanguage(currentLangIndex);
			
			intervalId = setInterval(() => {
				if (isAutoChanging) {
					currentLangIndex = (currentLangIndex + 1) % languages.length;
					changeLanguage(currentLangIndex);
				}
			}, 4000);
		}

		// Start auto-changing immediately
		autoChangeLanguage();

		languageButtons.forEach((button, index) => {
			button.addEventListener('click', () => {
				// Stop auto-changing
				isAutoChanging = false;
				clearInterval(intervalId);
				
				// Change to selected language with animation
				changeLanguage(index);
				
				// Update active button
				languageButtons.forEach(btn => btn.classList.remove('active'));
				button.classList.add('active');
			});
		});
	}

	// Initialize immediately when possible
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initializeLanguageSelector);
	} else {
		initializeLanguageSelector();
	}

	// Also initialize on view transitions
	document.addEventListener('astro:page-load', () => {
		if (cleanup) cleanup();
		cleanup = initializeObservers();
		initializeLanguageSelector();
	});

	// Cleanup on page unload
	document.addEventListener('astro:before-swap', () => {
		if (cleanup) cleanup();
	});
</script>
