---
import Layout from '../layouts/Layout.astro';

const content = {
  en: {
    title: "Hey, I'm Chris. I design cool stuff that just makes sense.",
    subtitle: "Simple, intuitive, and user-focused. Take a look around!"
  },
  es: {
    title: "Hola, soy Chris. Diseño cosas geniales que tienen sentido.",
    subtitle: "Simple, intuitivo y centrado en el usuario. ¡Echa un vistazo!"
  },

};

const currentLang = 'en'; // Default to English
---

<Layout>
	<main class="min-h-screen flex flex-col items-center justify-center px-4 md:pb-0 pb-24" id="hero-main">
		
		<div class="content-animation-container text-center max-w-3xl relative z-[40]">
			<h1 id="hero-title" class="text-4xl sm:text-6xl md:text-6xl font-bold mb-2 text-center">
				Hey, I'm Chris. I design cool stuff that just makes sense.
			</h1>
			<p id="hero-subtitle" class="text-base sm:text-lg md:text-xl text-gray-400 text-center">
				Simple, intuitive, and user-focused. Take a look around!
			</p>
		</div>
		
		<div class="absolute bottom-8 flex flex-col items-center pb-24 md:pb-0 z-[40]">
			<span class="text-gray-400">Scroll to explore</span>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mt-2 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
			</svg>
		</div>
	</main>


	<section class="max-w-[1000px] mx-auto relative text-white py-10 px-4 sm:px-6 lg:px-8" id="work-section">
		<h2 class="text-xl sm:text-2xl lg:text-3xl font-semibold text-left">Selected Work</h2>
	
		<div class="flex flex-col gap-10 mt-10">
			<!-- Work Item -->
			<div class="relative max-w-[1000px] p-6 border border-gray-700 rounded-2xl 
				bg-gradient-to-b from-[#2D2F36] to-[#1A1B1F] 
				hover:from-[#8C53DB] hover:to-[#1A1B1F] 
				gradient-transition text-white 
				min-h-[320px] sm:min-h-[600px] lg:min-h-[680px] 
				flex flex-col justify-end group">
				
				<!-- Arrow Icon -->
				<div class="absolute top-6 right-6 text-gray-400 hover:text-white transition">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
					</svg>
				</div>
	
				<!-- Title & Subtitle (Top-Left) -->
				<div class="sm:relative md:absolute top-6 left-6">
					<h2 class="text-lg sm:text-xl font-semibold text-white">Linda Caicedo Website</h2>
					<p class="text-sm sm:text-base text-gray-400">Player profile website</p>
				</div>
	
				<!-- Image Container -->
				<div class="border border-gray-600 rounded-lg overflow-hidden w-full 
					transition-transform duration-300 ease-in-out transform 
					group-hover:-translate-y-2 mt-4 sm:mt-0">
					<img 
						src="https://cdn.glitch.global/922fac7e-fd84-403d-88ed-7f031183e182/Group%203.png?v=1738825520534" 
						alt="Image"
						class="w-full h-auto object-cover" 
					/>
				</div>
			</div>

			
	
			<!-- Duplicate Work Item -->
			<div class="relative max-w-[1000px] p-6 border border-gray-700 rounded-2xl 
				bg-gradient-to-b from-[#2D2F36] to-[#1A1B1F] 
				hover:from-[#8C53DB] hover:to-[#1A1B1F] 
				gradient-transition text-white 
				min-h-[320px] sm:min-h-[600px] lg:min-h-[680px] 
				flex flex-col justify-end group">
				
				<!-- Arrow Icon -->
				<div class="absolute top-6 right-6 text-gray-400 hover:text-white transition">
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
					</svg>
				</div>
	
				<!-- Title & Subtitle (Top-Left) -->
				<div class="sm:relative md:absolute top-6 left-6">
					<h2 class="text-lg sm:text-xl font-semibold text-white">Linda Caicedo Website</h2>
					<p class="text-sm sm:text-base text-gray-400">Player profile website</p>
				</div>
	
				<!-- Image Container -->
				<div class="border border-gray-600 rounded-lg overflow-hidden w-full 
					transition-transform duration-300 ease-in-out transform 
					group-hover:-translate-y-2 mt-4 sm:mt-0">
					<img 
						src="https://cdn.glitch.global/922fac7e-fd84-403d-88ed-7f031183e182/Group%203.png?v=1738825520534" 
						alt="Image"
						class="w-full h-auto object-cover" 
					/>
				</div>
		</div>
	</section>
	

	<div class="min-h-screen text-white flex flex-col py-16 max-w-[880px] mx-auto px-6" id="about-section">
		<h1 class="text-xl font-semibold mb-8 w-full text-left">About me</h1>
		
		<div class="flex flex-col gap-8 w-full">
			{[1, 2, 3].map(() => (
				<div class="flex flex-col sm:flex-row items-start sm:items-center gap-8">
					<div class="w-full sm:w-76 h-48 sm:h-124 bg-gray-300 rounded-xl shrink-0"></div>
					<div>
						<h2 class="text-lg font-semibold mb-2">About me</h2>
						<p class="text-sm text-gray-400">
							Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
						</p>
					</div>
				</div>
			))}
		</div>
	</div>

	<section class="max-w-[880px] mx-auto text-white py-10 px-6" id="hobbies-section">
		<h2 class="text-2xl font-semibold mb-1 text-center">Challenges, Sports, Gaming</h2>
		<p class="text-gray-400 mb-15 text-center">The Fuel I always have enjoyed the most</p>
	  
		<div class="flex flex-wrap gap-8">
			<!-- Left Box with Bowling Text -->
			<div class="flex flex-col">
				<img 
					src="https://cdn.glitch.global/922fac7e-fd84-403d-88ed-7f031183e182/chris-desktop.jpg?v=1738798693750"
					alt="Bowling image" 
					class="w-94 h-124 object-cover rounded-xl"
				/>
				<div class="mt-4 mb-20">
					<p class="text-sm text-center">Currently competing in bowling</p>
					<p class="text-sm text-gray-400 text-center">(Is not that serious)</p>
				</div>
			</div>

			<!-- Right Box with Description -->
			<div class="flex flex-col">
				<img 
					src="https://cdn.glitch.global/922fac7e-fd84-403d-88ed-7f031183e182/chris-bowl.jpeg?v=1738651204173" 
					alt="Hobby image" 
					class="w-94 h-82 object-cover rounded-xl"
				/>
				<p class="text-gray-300 mt-4 text-sm max-w-md">
					Lorem ipsum dolor sit amet...
				</p>
			</div>
		</div>
	</section>
	

	
	<div class="text-white flex items-center mb-20 justify-center px-6">
		<div class="max-w-[880px] w-full">
			<h2 class="text-xl font-semibold mt-4 mb-5 border-t border-gray-500 pt-9">Experience</h2>

			<div class="space-y-12 mt-8">
				<!-- Azzule Experience -->
				<div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
