---
interface NavItem {
  name: string;
  url: string;
  icon: string; // We'll use SVG paths instead of Lucide icons
}

const navItems: NavItem[] = [
  {
    name: "Home",
    url: "/",
    icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
  },
  {
    name: "Projects",
    url: "/projects",
    icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
  }
];

const currentPath = Astro.url.pathname;
---

<div class="fixed bottom-0 sm:top-0 left-1/2 -translate-x-1/2 z-50 mb-6 sm:pt-6">
  <div class="flex items-center gap-3 bg-[#1a1e21]/5 border border-gray-800 backdrop-blur-lg py-2 px-3 rounded-full shadow-lg">
    {navItems.map((item) => {
      const isActive = currentPath === item.url;
      return (
        <a
          href={item.url}
          class:list={[
            "relative cursor-pointer text-sm font-semibold px-5 py-3 rounded-full transition-colors",
            "text-gray-400 hover:text-white",
            isActive && "bg-white/5 text-white nav-active"
          ]}
        >
          <span class="hidden md:inline">{item.name}</span>
          <span class="md:hidden">
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              class="h-[18px] w-[18px]" 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor" 
              stroke-width="2.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
          </span>
        </a>
      );
    })}
  </div>
</div>

<style>
  .nav-active {
    position: relative;
  }

  .nav-active::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(255 255 255 / 0.05);
    border-radius: 9999px;
    z-index: -1;
  }

  .nav-active::after {
    content: '';
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    width: 1.5rem;
    height: 0.25rem;
    background: rgb(255, 255, 255);
    border-radius: 9999px 9999px 0 0;
    box-shadow: 
      0 0 25px 5px rgba(255, 255, 255, 1),    /* Intense outer glow */
      0 0 15px 5px rgba(255, 255, 255, 1),    /* Strong middle glow */
      0 0 10px 5px rgba(255, 255, 255, 1),    /* Core glow */
      0 0 70px 7px rgba(255, 255, 255, 0.8),  /* Extended distant glow */
      0 0 100px 10px rgba(255, 255, 255, 0.6), /* Far-reaching glow */
      0 0 20px 5px rgba(255, 255, 255, 1);    /* Extra bright core */
  }

  /* Glow effects */
  .nav-active::after {
    box-shadow: 
      0 -8px 20px rgb(255 255 255 / 0.2),
      0 -4px 16px rgb(255 255 255 / 0.2),
      0 -2px 10px rgb(255 255 255 / 0.2);
  }
</style>

<script>
  // Add animation when changing pages
  document.addEventListener('astro:page-load', () => {
    const navLinks = document.querySelectorAll('a');
    navLinks.forEach(link => {
      if (link.getAttribute('aria-current') === 'page') {
        link.classList.add('nav-active');
      }
    });
  });
</script> 