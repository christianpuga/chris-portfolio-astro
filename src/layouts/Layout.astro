---
import "../styles/global.css";
import { ClientRouter } from 'astro:transitions';

const currentPath = Astro.url.pathname;
const navItems = [
  { path: '/', label: 'Home' },
  { path: '/projects', label: 'Projects' },
];
const isCurrentPage = (path: string) => {
  if (path === '/') {
    return currentPath === path;
  }
  return currentPath.startsWith(path);
};

// Footer.astro
interface Props {
  name?: string;
  year?: string;
  socialLinks?: {
    linkedin?: string;
    instagram?: string;
    dribbble?: string;
  };
}

const { 
  name = "Christian Puga",
  year = "2025",
  socialLinks = {
    linkedin: "#",
    instagram: "#",
    dribbble: "#"
  }
} = Astro.props;

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Christian Puga - UI/UX Designer</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
	<ClientRouter />
  </head>
  <body class="bg-[#1a1e21] text-white flex flex-col min-h-screen">
    <!-- Update gradient color to match background -->
    <div id="top-gradient" class="fixed top-0 left-0 w-full h-32 bg-gradient-to-b from-[#1a1e21]/95 to-transparent pointer-events-none opacity-0 transition-opacity duration-300 z-40"></div>
    
    <nav class="fixed w-full top-0 p-6 z-50 transition-all duration-1200" id="navbar">
		<div class="max-w-[410px] mx-auto">
			<!-- Mobile Menu -->
			<div class="flex items-center justify-start gap-3 sm:hidden">
				<button id="menu-toggle" class="text-white">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
				<span class="text-white text-sm font-medium">Menu</span>
			</div>

			<!-- Desktop Menu -->
			<div class="hidden sm:flex bg-white/10 backdrop-blur-sm rounded-full py-3 px-4 items-center justify-between gap-0">
				{navItems.map(({ path, label }) => (
					<a
						href={path}
						class:list={[
							'px-8 py-4 rounded-full text-sm font-medium transition-all duration-200',
							isCurrentPage(path) 
								? 'bg-[#E8E8E8]/.5 backdrop-blur-sm text-white'
								: 'text-[#E8E8E8] hover:bg-white/10'
						]}
					>
						{label}
					</a>
				))}
				<a 
					href="/contact" 
					class="inline-flex items-center bg-[#1C1C1C] text-white px-5 py-3.5 rounded-full text-sm font-medium hover:bg-[#2C2C2C] transition-colors whitespace-nowrap group"
				>
					Let's Talk
					<span class="ml-2 bg-[#D8FB45] rounded-full p-1 flex items-center justify-center transform transition-transform group-hover:translate-x-0.5">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-[#1a1e21]" viewBox="0 0 20 20" fill="currentColor">
							<path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
						</svg>
					</span>
				</a>
			</div>

			<!-- Mobile Menu Panel -->
			<div id="mobile-menu" class="fixed inset-0 bg-[#1a1e21] z-[100] transform translate-y-full transition-all duration-500 ease-in-out sm:hidden min-h-screen">
				<div class="w-full h-full p-8 flex flex-col">
					<div class="flex items-center gap-3">
						<a 
							href={currentPath} 
							id="menu-close" 
							class="text-white p-2" 
							aria-label="Close menu"
						>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
							</svg>
						</a>
						<span class="text-white text-sm font-medium">Menu</span>
					</div>
					<div class="flex flex-col gap-8 justify-center items-center h-full -mt-16">
						{navItems.map(({ path, label }) => (
							<a
								href={path}
								class:list={[
									'text-3xl font-medium transition-colors text-center',
									isCurrentPage(path) 
										? 'text-white'
										: 'text-gray-400 hover:text-white'
								]}
							>
								{label}
							</a>
						))}
						<a 
							href="/contact" 
							class="text-3xl font-medium text-gray-400 hover:text-white transition-colors text-center"
						>
							Let's Talk
						</a>
					</div>
				</div>
			</div>
		</div>
	</nav>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="w-full mt-20 border-t border-gray-700 pt-20 text-white py-16">
      <div class="max-w-[880px] mx-auto px-">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center space-y-4 md:space-y-0">
          <!-- Left side with title and links -->
          <div class="space-y-4">
            <p class="text-lg font-normal">
              MX - {year} {name}.
            </p>
            <nav class="flex space-x-6">
              <a 
                href={socialLinks.linkedin}
                class="text-gray-300 hover:text-white transition-colors"
              >
                Linkedin
              </a>
              <a 
                href={socialLinks.instagram}
                class="text-gray-300 hover:text-white transition-colors"
              >
                Instagram
              </a>
              <a 
                href={socialLinks.dribbble}
                class="text-gray-300 hover:text-white transition-colors"
              >
                Dribbble
              </a>
            </nav>
          </div>
    
          <!-- Right side with portfolio text -->
          <div>
            <p class="text-gray-300">Portfolio in constant progress.</p>
          </div>
        </div>
      </div>
    </footer>

<script>
	let cleanup: (() => void) | null = null;

	function initializeNavigation() {
		let lastScrollY = window.scrollY;
		let ticking = false;

		// Mobile menu functionality
		const menuToggle = document.getElementById('menu-toggle');
		const menuClose = document.getElementById('menu-close');
		const mobileMenu = document.getElementById('mobile-menu');
		const body = document.body;

		function handleMenuOpen() {
			if (mobileMenu && body) {
				mobileMenu.classList.remove('translate-y-full');
				body.style.overflow = 'hidden';
			}
		}

		function handleMenuClose() {
			if (mobileMenu && body) {
				mobileMenu.classList.add('translate-y-full');
				body.style.overflow = '';
			}
		}

		// Add event listeners
		menuToggle?.addEventListener('click', handleMenuOpen);
		menuClose?.addEventListener('click', handleMenuClose);

		// Also close menu when clicking links
		const menuLinks = mobileMenu?.querySelectorAll('a');
		menuLinks?.forEach(link => {
			link.addEventListener('click', handleMenuClose);
		});

		// Handle resize events
		const handleResize = () => {
			if (window.innerWidth >= 640) {
				handleMenuClose();
			}
		};

		// Scroll functionality
		const scrollHandler = () => {
			if (!ticking) {
				window.requestAnimationFrame(() => {
					const navbar = document.getElementById('navbar');
					const gradient = document.getElementById('top-gradient');
					const currentScrollY = window.scrollY;

					if (navbar && gradient) {
						if (currentScrollY > lastScrollY && currentScrollY > 10) {
							navbar.style.transform = 'translateY(-100%)';
							navbar.style.opacity = '0';
							gradient.style.opacity = '1';
						} else {
							navbar.style.transform = 'translateY(0)';
							navbar.style.opacity = '1';
							gradient.style.opacity = currentScrollY > 10 ? '1' : '0';
						}
					}

					lastScrollY = currentScrollY;
					ticking = false;
				});

				ticking = true;
			}
		};

		window.addEventListener('resize', handleResize);
		window.addEventListener('scroll', scrollHandler);

		// Return cleanup function
		return () => {
			menuToggle?.removeEventListener('click', handleMenuOpen);
			menuClose?.removeEventListener('click', handleMenuClose);
			menuLinks?.forEach(link => {
				link.removeEventListener('click', handleMenuClose);
			});
			window.removeEventListener('resize', handleResize);
			window.removeEventListener('scroll', scrollHandler);
		};
	}

	// Initialize on first load
	document.addEventListener('DOMContentLoaded', () => {
		cleanup = initializeNavigation();
	});

	// Initialize after view transitions
	document.addEventListener('astro:page-load', () => {
		if (cleanup) cleanup();
		cleanup = initializeNavigation();
	});

	// Cleanup on page unload
	document.addEventListener('astro:before-swap', () => {
		if (cleanup) cleanup();
	});
</script>
  </body>
</html>

